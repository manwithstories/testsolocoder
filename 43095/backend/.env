ENVIRONMENT=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=medical_platform
DB_SSLMODE=disable

JWT_SECRET=your-secret-key-change-in-production-please
JWT_EXPIRE=86400

LOG_LEVEL=debug

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@medical.com

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
