# ==================== Server ====================
SERVER_PORT=8080
SERVER_MODE=release
SERVER_READ_TIMEOUT=60
SERVER_WRITE_TIMEOUT=60

# ==================== Database ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=music_platform
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100

# ==================== JWT ====================
JWT_SECRET=your-jwt-secret-key-please-change-it
JWT_EXPIRE_HOUR=72
JWT_ISSUER=music-platform

# ==================== Upload ====================
UPLOAD_MAX_SIZE=52428800
UPLOAD_AUDIO_PATH=./uploads/audio
UPLOAD_IMAGE_PATH=./uploads/images

# ==================== Log ====================
LOG_LEVEL=info
LOG_FILENAME=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
