# Server Config
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# MySQL Config
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=ticket_system

# Redis Config
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Config
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE_HOURS=24

# Seat Lock Config
SEAT_LOCK_MINUTES=15

# Log Config
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Email Config (SMTP)
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=ticket@example.com

# SMS Config
SMS_ACCESS_KEY=your-access-key
SMS_SECRET_KEY=your-secret-key
SMS_SIGN_NAME=票务系统

# Payment Config
ALIPAY_APP_ID=your-alipay-app-id
WECHAT_APP_ID=your-wechat-app-id
