# ====== 基础配置 ======
RSS_DATA_DIR=~/.rss_reader
RSS_DB_URL=
RSS_LOG_LEVEL=INFO
RSS_USER_AGENT="Mozilla/5.0 (compatible; RSSReader/0.1)"

# ====== 抓取配置 ======
RSS_REQUEST_TIMEOUT=30
RSS_MAX_RETRIES=3
RSS_RETRY_INTERVAL=5

# ====== 去重配置 ======
RSS_DEDUP_THRESHOLD=3

# ====== 报告配置 ======
RSS_REPORT_TIME=08:00
RSS_REPORT_FORMAT=markdown

# ====== SMTP 邮件配置 ======
RSS_SMTP_HOST=smtp.gmail.com
RSS_SMTP_PORT=587
RSS_SMTP_USERNAME=your-email@gmail.com
RSS_SMTP_PASSWORD=your-app-password
RSS_SMTP_USE_TLS=true
RSS_SMTP_FROM_ADDR=your-email@gmail.com
RSS_SMTP_TO_ADDRS=recipient1@example.com,recipient2@example.com
